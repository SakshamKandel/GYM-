# Copy to .env and fill in. NEVER commit .env.

# Neon Postgres (cloud source of truth) — from the Neon console connection dialog
DATABASE_URL=

# Optional: free USDA FoodData Central key (https://fdc.nal.usda.gov/api-key-signup)
# Without it the app uses DEMO_KEY (rate-limited) for web food search.
EXPO_PUBLIC_USDA_API_KEY=

# Mobile → API base URL (apps/web). Default: http://localhost:3000
EXPO_PUBLIC_API_URL=
NEXT_PUBLIC_SITE_URL=https://your-production-domain.example

# Google Sign-In OAuth client ids (Google Cloud console > Credentials); leave empty to keep the button disabled
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Web API: accepted Google ID-token audiences. GOOGLE_CLIENT_ID should be the
# same WEB client embedded in the app. GOOGLE_CLIENT_IDS may contain the web,
# Android, and iOS client IDs as a comma-separated compatibility list.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_IDS=
