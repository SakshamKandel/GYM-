# EAS build upload filter. When this file exists, EAS CLI uses it INSTEAD of
# .gitignore — it mirrors .gitignore with ONE deliberate difference:
# apps/mobile/google-services.json IS uploaded (app.json references it; it holds
# only a package-restricted Firebase key, safe for build machines).

# Dependencies
node_modules/
.pnp
.pnp.js

# Builds & output
dist/
build/
out/
.next/
coverage/
web-build/

# Expo / native (regenerated by prebuild on the build machine)
.expo/
.expo-shared/
expo-env.d.ts
*.orig.*
apps/mobile/android/
apps/mobile/ios/
.kotlin/
.metro-health-check*

# Environment & secrets — NEVER uploaded (eas.json env provides EXPO_PUBLIC_*)
.env
.env.*
!.env.example
*.pem
*.key
*.jks
*.p8
*.p12
*.mobileprovision

# Logs & caches
logs/
*.log
.cache/
.turbo/
.eslintcache
*.tsbuildinfo

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini

# Git internals
.git/
